
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>PAVOI Inspire · Team Setup Guide</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:#f0f1ef;color:#282828;-webkit-font-smoothing:antialiased}

/* ── TOP NAV ── */
.top-bar{background:#2e4042;padding:0 32px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.top-brand{color:#fff;font-weight:700;font-size:15px;letter-spacing:3px;text-transform:uppercase}
.top-sub{color:#a9bdb6;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase}
.top-nav{display:flex;gap:8px;flex-wrap:wrap}
.top-nav a{color:#a9bdb6;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1px;text-transform:uppercase;text-decoration:none;padding:5px 10px;border:1px solid #3f5a5d;border-radius:2px;transition:all .2s}
.top-nav a:hover{color:#fff;border-color:#a9bdb6}

/* ── HERO ── */
.hero{background:#2e4042;padding:64px 32px 56px;text-align:center}
.hero-eyebrow{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#a9bdb6;margin-bottom:16px}
.hero-title{font-size:38px;font-weight:700;color:#fff;line-height:1.2;margin-bottom:16px}
.hero-sub{font-size:17px;color:rgba(255,255,255,.65);max-width:560px;margin:0 auto 32px;line-height:1.6}
.hero-pills{display:flex;flex-wrap:wrap;gap:10px;justify-content:center}
.hero-pill{background:rgba(255,255,255,.1);color:#fff;padding:8px 18px;border-radius:2px;font-size:13px;font-weight:500;letter-spacing:.3px}

/* ── LAYOUT ── */
.page{max-width:860px;margin:0 auto;padding:48px 24px}

/* ── SECTION ── */
.section{margin-bottom:56px}
.section-header{display:flex;align-items:center;gap:16px;margin-bottom:28px;padding-bottom:16px;border-bottom:2px solid #2e4042}
.section-num{width:40px;height:40px;border-radius:2px;background:#2e4042;color:#fff;font-family:'Space Mono',monospace;font-size:16px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.section-title-block{}
.section-title{font-size:22px;font-weight:700;color:#2e4042;line-height:1.2}
.section-badge{display:inline-flex;align-items:center;gap:5px;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;padding:3px 9px;border-radius:2px;margin-top:5px}
.badge-desktop{background:#e8f2ee;color:#2e4042}
.badge-mobile{background:#fdf4e1;color:#7a6535}
.badge-both{background:#e6e7e5;color:#6b7b79}

/* ── STEP CARDS ── */
.steps{display:flex;flex-direction:column;gap:12px}
.step{display:flex;gap:16px;background:#fff;border-radius:8px;padding:20px;box-shadow:0 1px 8px rgba(46,64,66,.07)}
.step-num{width:32px;height:32px;border-radius:50%;background:#2e4042;color:#fff;font-family:'Space Mono',monospace;font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.step-body{flex:1}
.step-action{font-size:15px;font-weight:600;color:#282828;margin-bottom:4px;line-height:1.4}
.step-detail{font-size:14px;color:#6b7b79;line-height:1.55}
.step-highlight{display:inline-block;background:#f0f1ef;border:1px solid #cdd0ce;border-radius:4px;padding:3px 10px;font-family:'Space Mono',monospace;font-size:12px;color:#2e4042;margin:6px 0;word-break:break-all}
.step-tip{margin-top:10px;padding:10px 14px;background:#e8f2ee;border-left:3px solid #2e4042;border-radius:0 4px 4px 0;font-size:13px;color:#2e4042;line-height:1.5}
.step-warn{margin-top:10px;padding:10px 14px;background:#fdf4e1;border-left:3px solid #e0a800;border-radius:0 4px 4px 0;font-size:13px;color:#7a6535;line-height:1.5}

/* ── CALLOUT ── */
.callout{background:#2e4042;border-radius:8px;padding:24px 28px;margin-bottom:28px;display:flex;gap:16px;align-items:flex-start}
.callout-icon{font-size:24px;flex-shrink:0;margin-top:2px}
.callout-body{}
.callout-title{font-size:15px;font-weight:700;color:#fff;margin-bottom:6px}
.callout-text{font-size:14px;color:rgba(255,255,255,.7);line-height:1.6}

/* ── TWO COL ── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px}
@media(max-width:600px){.two-col{grid-template-columns:1fr}}
.col-card{background:#fff;border-radius:8px;padding:20px;box-shadow:0 1px 8px rgba(46,64,66,.07)}
.col-card-title{font-size:14px;font-weight:700;color:#2e4042;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.col-card ul{list-style:none;display:flex;flex-direction:column;gap:8px}
.col-card ul li{font-size:13px;color:#444;line-height:1.5;display:flex;gap:8px}
.col-card ul li::before{content:'→';color:#a9bdb6;flex-shrink:0;font-family:'Space Mono',monospace;font-size:11px;margin-top:2px}

/* ── URL BLOCK ── */
.url-block{background:#1a2a2b;border-radius:6px;padding:14px 18px;margin:12px 0;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.url-text{font-family:'Space Mono',monospace;font-size:13px;color:#a9bdb6;word-break:break-all}
.url-copy-btn{background:#2e4042;color:#fff;border:none;border-radius:2px;padding:7px 14px;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;flex-shrink:0;transition:background .15s}
.url-copy-btn:hover{background:#3f5a5d}
.url-copy-btn.copied{background:#a9bdb6;color:#2e4042}

/* ── SCREEN MOCK ── */
.screen-mock{background:#fff;border:2px solid #e6e7e5;border-radius:12px;overflow:hidden;margin:16px 0;box-shadow:0 4px 20px rgba(46,64,66,.1)}
.screen-bar{background:#2e4042;height:40px;display:flex;align-items:center;padding:0 16px;gap:8px}
.screen-dot{width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,.2)}
.screen-url-bar{flex:1;background:rgba(255,255,255,.1);border-radius:20px;height:24px;margin:0 12px;display:flex;align-items:center;padding:0 12px}
.screen-url-text{font-family:'Space Mono',monospace;font-size:10px;color:rgba(255,255,255,.5);overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.screen-body{padding:20px}
.screen-body p{font-size:13px;color:#6b7b79;line-height:1.6}

/* ── PHONE MOCK ── */
.phone-wrap{display:flex;justify-content:center;margin:20px 0}
.phone{width:200px;background:#1a2a2b;border-radius:28px;padding:8px;box-shadow:0 8px 32px rgba(46,64,66,.3)}
.phone-screen{background:#f0f1ef;border-radius:22px;overflow:hidden;min-height:320px;display:flex;flex-direction:column}
.phone-status{background:#2e4042;height:28px;display:flex;align-items:center;justify-content:center}
.phone-status-text{font-family:'Space Mono',monospace;font-size:8px;color:#a9bdb6;letter-spacing:1px}
.phone-content{flex:1;padding:12px}
.phone-content p{font-size:10px;color:#282828;line-height:1.6;margin-bottom:8px}
.phone-share-bar{background:#fff;border-top:1px solid #e6e7e5;padding:8px 12px;display:flex;align-items:center;justify-content:space-around}
.phone-share-icon{width:36px;height:36px;border-radius:8px;background:#2e4042;display:flex;align-items:center;justify-content:center;font-size:14px}
.phone-share-label{font-size:8px;color:#6b7b79;text-align:center;margin-top:3px;font-family:'Space Mono',monospace;letter-spacing:.5px}

/* ── SHARE SHEET MOCK ── */
.share-sheet{background:#fff;border-radius:12px;padding:16px;margin:16px 0;box-shadow:0 4px 20px rgba(46,64,66,.12)}
.share-sheet-title{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:#a9bdb6;margin-bottom:12px}
.share-sheet-row{display:flex;gap:16px;overflow-x:auto;padding-bottom:8px;scrollbar-width:none}
.share-sheet-row::-webkit-scrollbar{display:none}
.share-icon-wrap{display:flex;flex-direction:column;align-items:center;gap:5px;flex-shrink:0}
.share-icon{width:52px;height:52px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px}
.share-icon.teal{background:#2e4042}
.share-icon.blue{background:#0077b5}
.share-icon.green{background:#25d366}
.share-icon.gray{background:#e6e7e5}
.share-icon.highlight{background:#2e4042;box-shadow:0 0 0 3px #a9bdb6}
.share-label{font-size:10px;color:#282828;text-align:center;font-weight:500;max-width:56px}

/* ── DIVIDER ── */
.divider{height:1px;background:#e6e7e5;margin:12px 0}

/* ── ACTIONS REQUIRED BADGE ── */
.req-badge{display:inline-flex;align-items:center;gap:4px;background:#c0392b;color:#fff;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1px;text-transform:uppercase;padding:3px 9px;border-radius:2px;margin-left:8px;vertical-align:middle}

/* ── FOOTER ── */
.footer{background:#1a2a2b;padding:32px;text-align:center}
.footer-brand{color:#fff;font-weight:700;font-size:15px;letter-spacing:3px;text-transform:uppercase;margin-bottom:8px}
.footer-text{font-family:'Space Mono',monospace;font-size:10px;color:#6b7b79;letter-spacing:1px}

/* ── RESPONSIVE ── */
@media(max-width:640px){
  .top-nav{display:none}
  .hero{padding:40px 20px}
  .hero-title{font-size:28px}
  .page{padding:32px 16px}
}
</style>
</head>
<body>

<div class="top-bar">
  <div>
    <div class="top-brand">PAVOI</div>
  </div>
  <nav class="top-nav">
    <a href="#web">Web</a>
    <a href="#bookmarklet">Bookmarklet</a>
    <a href="#mobile">Mobile</a>
    <a href="#inspire-home">Inspire App</a>
    <a href="#capture-home">Capture App</a>
    <a href="#share">Share from Browser</a>
    <a href="#shortcut" style="background:rgba(169,189,182,.15);border-color:#a9bdb6;color:#fff">⚡ Shortcut</a>
  </nav>
</div>

<div class="hero">
  <div class="hero-eyebrow">Internal Team Guide</div>
  <div class="hero-title">PAVOI Inspire<br>Setup &amp; Access</div>
  <div class="hero-sub">Everything you need to access the Inspire app, capture inspiration, and add things to the feed — on any device.</div>
  <div class="hero-pills">
    <div class="hero-pill">💻 Desktop</div>
    <div class="hero-pill">📱 iPhone</div>
    <div class="hero-pill">🔖 Bookmarklet</div>
    <div class="hero-pill">⚡ Share from Any App</div>
    <div class="hero-pill">🔁 iOS Shortcut</div>
  </div>
</div>

<div class="page">

  <!-- ── SECTION 1: WEB ACCESS ── -->
  <div class="section" id="web">
    <div class="section-header">
      <div class="section-num">1</div>
      <div class="section-title-block">
        <div class="section-title">Access on the Web</div>
        <span class="section-badge badge-both">💻 Desktop &amp; 📱 Mobile</span>
      </div>
    </div>

    <div class="callout">
      <div class="callout-icon">🔗</div>
      <div class="callout-body">
        <div class="callout-title">Your two apps</div>
        <div class="callout-text">PAVOI Inspire has two sides — <strong style="color:#fff">Capture</strong> (for saving inspiration) and <strong style="color:#fff">Digest</strong> (for voting and reviewing what the team has saved). Bookmark both.</div>
      </div>
    </div>

    <div class="two-col">
      <div class="col-card">
        <div class="col-card-title">📸 Capture App</div>
        <div style="font-size:13px;color:#6b7b79;margin-bottom:10px">Use this to save new inspiration — photos, links, screenshots.</div>
        <div class="url-block">
          <span class="url-text">hannah744.github.io/pavoi-inspire/pavoi-capture.html</span>
          <button class="url-copy-btn" onclick="copyUrl(this,'https://hannah744.github.io/pavoi-inspire/pavoi-capture.html')">Copy</button>
        </div>
      </div>
      <div class="col-card">
        <div class="col-card-title">🗳 Digest App</div>
        <div style="font-size:13px;color:#6b7b79;margin-bottom:10px">Use this to vote on the week's inspiration and see results.</div>
        <div class="url-block">
          <span class="url-text">script.google.com/a/macros/pavoi.com/s/AKfycbyoBHn9rdIsEry39mdTpoblGaGoQ4iAkF2GgvCSIzIBK6qhhl5PD5z_OehbfNTVjdte4Q/exec</span>
          <button class="url-copy-btn" onclick="copyUrl(this,'https://script.google.com/a/macros/pavoi.com/s/AKfycbyoBHn9rdIsEry39mdTpoblGaGoQ4iAkF2GgvCSIzIBK6qhhl5PD5z_OehbfNTVjdte4Q/exec')">Copy</button>
        </div>
      </div>
    </div>

    <div class="steps" style="margin-top:20px">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-body">
          <div class="step-action">Open your browser</div>
          <div class="step-detail">Chrome, Safari, Firefox — any browser works on both Mac and PC.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-body">
          <div class="step-action">Go to the URL above for the app you want</div>
          <div class="step-detail">Paste it into the address bar at the top of your browser and hit Enter.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-body">
          <div class="step-action">Bookmark it so you can find it quickly next time</div>
          <div class="step-detail">Press <strong>⌘D</strong> (Mac) or <strong>Ctrl+D</strong> (PC) to save it to your bookmarks.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── SECTION 2: BOOKMARKLET ── -->
  <div class="section" id="bookmarklet">
    <div class="section-header">
      <div class="section-num">2</div>
      <div class="section-title-block">
        <div class="section-title">Install the Desktop Bookmarklet</div>
        <span class="section-badge badge-desktop">💻 Desktop only</span>
      </div>
    </div>

    <div class="callout">
      <div class="callout-icon">🔖</div>
      <div class="callout-body">
        <div class="callout-title">What's a bookmarklet?</div>
        <div class="callout-text">It's a special bookmark in your browser toolbar. When you click it while browsing any website — Amazon, Pinterest, a competitor's site — it instantly opens a Capture form pre-filled with the page's URL and image. One click to save anything.</div>
      </div>
    </div>

    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-body">
          <div class="step-action">Make sure your bookmarks bar is visible</div>
          <div class="step-detail">In Chrome or Safari, press <strong>⌘⇧B</strong> (Mac) or <strong>Ctrl+Shift+B</strong> (PC) to show it. You should see a row of bookmarks just below the address bar.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-body">
          <div class="step-action">Open the Bookmarklet Setup page</div>
          <div class="url-block">
            <span class="url-text">hannah744.github.io/pavoi-inspire/pavoi-bookmarklet.html</span>
            <button class="url-copy-btn" onclick="copyUrl(this,'https://hannah744.github.io/pavoi-inspire/pavoi-bookmarklet.html')">Copy</button>
          </div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-body">
          <div class="step-action">Find the "PAVOI Capture" button on that page</div>
          <div class="step-detail">There will be a clearly labeled button that says something like <strong>"📸 PAVOI Capture"</strong>.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <div class="step-body">
          <div class="step-action">Drag that button up to your bookmarks bar</div>
          <div class="step-detail">Click and hold the button, then drag it up to the bookmarks bar and release. It should appear there as a new bookmark.</div>
          <div class="step-tip">💡 If dragging doesn't work: right-click the button → "Copy Link" → right-click your bookmarks bar → "Add Page" → paste the link as the URL.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">5</div>
        <div class="step-body">
          <div class="step-action">Test it — go to any product page and click the bookmarklet</div>
          <div class="step-detail">Navigate to any product or inspiration page. Click "PAVOI Capture" in your bookmarks bar. A capture form should open with the page link and image already filled in.</div>
        </div>
      </div>
    </div>

    <div class="screen-mock" style="margin-top:20px">
      <div class="screen-bar">
        <div class="screen-dot"></div><div class="screen-dot"></div><div class="screen-dot"></div>
        <div class="screen-url-bar"><div class="screen-url-text">amazon.com/dp/product-page</div></div>
        <div style="color:#a9bdb6;font-size:11px;font-family:'Space Mono',monospace;cursor:pointer;border:1px solid #3f5a5d;padding:3px 8px;border-radius:2px">📸 PAVOI Capture</div>
      </div>
      <div class="screen-body">
        <p>← The bookmarklet lives in your browser toolbar. Click it on any page to instantly open a capture form pre-filled with the product image and URL.</p>
      </div>
    </div>
  </div>

  <!-- ── SECTION 3: MOBILE ACCESS ── -->
  <div class="section" id="mobile">
    <div class="section-header">
      <div class="section-num">3</div>
      <div class="section-title-block">
        <div class="section-title">Access on Your Phone</div>
        <span class="section-badge badge-mobile">📱 iPhone</span>
      </div>
    </div>

    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-body">
          <div class="step-action">Open Safari on your iPhone</div>
          <div class="step-detail">These apps are designed for Safari on iOS. They will work in Chrome too, but "Add to Home Screen" works best in Safari.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-body">
          <div class="step-action">Go to the URL for the app you want</div>
          <div class="step-detail">Tap the address bar, type or paste the URL, and tap Go.</div>
          <div class="step-highlight">hannah744.github.io/pavoi-inspire/pavoi-capture.html</div><br>
          <div class="step-highlight">script.google.com/a/macros/pavoi.com/s/AKfycby...exec</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-body">
          <div class="step-action">The app loads — you're in!</div>
          <div class="step-detail">Both apps are built to look and feel like native iPhone apps. Select your name from the dropdown and you're ready to go.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── SECTION 4: INSPIRE TO HOME SCREEN ── -->
  <div class="section" id="inspire-home">
    <div class="section-header">
      <div class="section-num">4</div>
      <div class="section-title-block">
        <div class="section-title">Add the Digest App to Your Home Screen</div>
        <span class="section-badge badge-mobile">📱 iPhone · Safari</span>
      </div>
    </div>

    <div class="callout">
      <div class="callout-icon">📲</div>
      <div class="callout-body">
        <div class="callout-title">Why add it to your home screen?</div>
        <div class="callout-text">Adding it to your home screen makes it feel like a real app — it opens full screen with no browser chrome, launches faster, and sits right on your home screen next to your other apps.</div>
      </div>
    </div>

    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-body">
          <div class="step-action">Open Safari and go to the Digest app</div>
          <div class="step-highlight">script.google.com/a/macros/pavoi.com/s/AKfycby...exec</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-body">
          <div class="step-action">Tap the Share button at the bottom of Safari</div>
          <div class="step-detail">It looks like a box with an arrow pointing up ↑. It's in the middle of the toolbar at the bottom of your screen.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-body">
          <div class="step-action">Scroll down in the Share Sheet and tap "Add to Home Screen"</div>
          <div class="step-detail">You may need to scroll down in the list to find it. It has a plus sign icon.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <div class="step-body">
          <div class="step-action">Name it and tap "Add"</div>
          <div class="step-detail">Change the name to <strong>PAVOI Digest</strong> (or whatever you'd like), then tap "Add" in the top right corner.</div>
        </div>
      </div>
      <div class="step">
        <div class="step-num">5</div>
        <div class="step-body">
          <div class="step-action">Find the icon on your home screen</div>
          <div class="step-detail">It'll appear on your home screen just like a regular app. Tap it to open — no browser bar, full screen.</div>
          <div class="step-tip">💡 You can move the icon to your main home screen by pressing and holding it, then dragging it to wherever you want.</div>
        </div>
      </div>
    </div>

    <div style="margin-top:20px">
      <div style="font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:#a9bdb6;margin-bottom:12px">What you're looking for in Safari</div>
